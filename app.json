{
  "expo": {
    "name": "Walburg College",
    "slug": "walburg",
    "scheme": [
      "walburgcollege",
      "m6loapp"
    ],
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D8E68"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "nl.walburgcollege.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "nl.walburgcollege.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      "expo-web-browser",
      "expo-font",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.nl.walburgcollege.app",
          "widgets": [
            {
              "name": "WalburgNextLessonWidget",
              "displayName": "Volgende les",
              "description": "Toon je eerstvolgende les op het beginscherm.",
              "supportedFamilies": [
                "systemSmall"
              ]
            },
            {
              "name": "WalburgTodayAgendaWidget",
              "displayName": "Schoolagenda vandaag",
              "description": "Laat het eerstvolgende item uit de schoolagenda van vandaag zien.",
              "supportedFamilies": [
                "systemSmall"
              ]
            },
            {
              "name": "WalburgLatestGradeWidget",
              "displayName": "Laatste cijfer",
              "description": "Laat je meest recente cijfer direct op het beginscherm zien.",
              "supportedFamilies": [
                "systemSmall"
              ]
            },
            {
              "name": "WalburgNextLessonAgendaWidget",
              "displayName": "Les + agenda",
              "description": "Combineert je eerstvolgende les met het belangrijkste agenda-item van vandaag.",
              "supportedFamilies": [
                "systemMedium"
              ]
            },
            {
              "name": "WalburgNextLessonGradeWidget",
              "displayName": "Les + cijfer",
              "description": "Combineert je eerstvolgende les met je meest recente cijfer.",
              "supportedFamilies": [
                "systemMedium"
              ]
            }
          ]
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "nl.walburgcollege.app.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.nl.walburgcollege.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "a6585cef-203f-49f8-9317-b168f8b9d5f1"
      }
    },
    "owner": "info.leesloods"
  }
}
